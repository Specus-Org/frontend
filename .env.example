# ============================================================
# PUBLIC VARIABLES (exposed to the browser -- no secrets here)
# ============================================================

# Base URL for the Specus backend API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Bangladesh Procurement Analysis dashboard
NEXT_PUBLIC_BANGLADESH_DASHBOARD_URL=

# Indonesia Procurement Analysis dashboard
NEXT_PUBLIC_INDONESIA_DASHBOARD_URL=

# Paraguay Procurement Analysis dashboard (Apache Superset, owned by another team)
NEXT_PUBLIC_PARAGUAY_DASHBOARD_URL=

# ============================================================
# SERVER / BUILD-TIME ONLY (never sent to the browser)
# ============================================================

# Note: OpenAPI spec fetching now uses `gh` CLI (gh auth login) instead of GITHUB_TOKEN

# Auth.js v5 session encryption secret
# Generate with: npx auth secret
AUTH_SECRET=

# Trust the Host header from the reverse proxy (set to "true" in production
# ONLY if your proxy strips/validates X-Forwarded-Host before forwarding)
AUTH_TRUST_HOST=true
