{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": [
    "NEXT_PUBLIC_API_BASE_URL",
    "AUTH_SECRET",
    "AUTH_TRUST_HOST",
    "AUTH_AUTHENTIK_ID",
    "AUTH_AUTHENTIK_SECRET",
    "AUTH_AUTHENTIK_ISSUER"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
