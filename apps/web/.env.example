# Backend API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Bangladesh Procurement Analysis dashboard
NEXT_PUBLIC_BANGLADESH_DASHBOARD_URL=

# Indonesia Procurement Analysis dashboard
NEXT_PUBLIC_INDONESIA_DASHBOARD_URL=

# Paraguay Procurement Analysis dashboard (Apache Superset)
NEXT_PUBLIC_PARAGUAY_DASHBOARD_URL=

# NextAuth secret — generate with: openssl rand -hex 32
AUTH_SECRET=

# Required when running behind a reverse proxy or in production
AUTH_TRUST_HOST=true

# GitHub token (used for fetching content or other GitHub API calls)
GITHUB_TOKEN=
